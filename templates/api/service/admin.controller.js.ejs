import { fileURLToPath } from 'url';
import Core from '@ydmnypg/core';

const __dirname = fileURLToPath(new URL('.', import.meta.url));

class Admin<%= serviceName.camel %>Controller extends Core.Controller {
  constructor(service) {
    super({ service });
    this.scopes = ['admin'];
    this.tags = ['<%= serviceName.lower %>'];
  }

  static routers() {
    return this.autoLoad(__dirname, { excludes: [] });
  }
}

export default Admin<%= serviceName.camel %>Controller;

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="<%= modelName.namespace %>">

  <sql id="columns"><%= modelName.lower %>.*</sql>

  <sql id="from">${TABLE_<%= modelName.upper %>} AS <%= modelName.lower %></sql>

  <sql id="where">
    (1 = 1)
    <if test="id != null and id != ''"> AND <%= modelName.lower %>.id = #{id} </if>
  </sql>

  <sql id="orderBy">
    ORDER BY
    <choose>
      <when test="sort != null and sort != ''"><%= modelName.lower %>.${sort} ${order != null ? order : 'DESC'}</when>
      <otherwise><%= modelName.lower %>.id DESC</otherwise>
    </choose>
  </sql>

  <select id="findOne">
    SELECT <include refid="columns"/>
    FROM <include refid="from"/>
    WHERE <include refid="where"/>
    LIMIT 1
  </select>

  <select id="findAll">
    SELECT <include refid="columns"/>
    FROM <include refid="from"/>
    WHERE <include refid="where"/>
    <include refid="orderBy"/>
    <if test="page != null and size != null">LIMIT ${size} OFFSET ${page}</if>
  </select>

  <select id="count">
    SELECT COUNT(<%= modelName.lower %>.id) AS total
    FROM <include refid="from"/>
    WHERE <include refid="where"/>
  </select>
</mapper>
